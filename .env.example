# Copy this file to .env and fill in your actual values

# Server-side variables (for Vercel deployment)
# Set these in your Vercel dashboard under Environment Variables

# Your Notion integration API key
# Get it from: https://www.notion.so/profile/integrations
NOTION_TOKEN=your-token

# Your Bolsai API key
BOLSAI_API_KEY=your-key

# Notion API version (optional, defaults to 2022-06-28)
NOTION_API_VERSION=2022-06-28

# Your Notion FII database ID
FII_DATABASE_ID=your-database-id
